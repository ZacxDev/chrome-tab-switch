{
  "manifest_version": 3,
  "name": "Tab Switcher",
  "version": "1.0",
  "permissions": ["tabs"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "switch-to-next-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "MacCtrl+Shift+L"
      },
      "description": "Switch to the next tab"
    },
    "switch-to-prev-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "MacCtrl+Shift+H"
      },
      "description": "Switch to the previous tab"
    },
    "move-tab-right": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "MacCtrl+Shift+Period"
      },
      "description": "Move the current tab right"
    },
    "move-tab-left": {
      "suggested_key": {
        "default": "Ctrl+Shift+Comma",
        "mac": "MacCtrl+Shift+Comma"
      },
      "description": "Move the current tab left"
    }
  }
}

